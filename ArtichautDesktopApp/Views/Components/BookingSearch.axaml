<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ArtichautDesktopApp.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ArtichautDesktopApp.Views.Components.BookingSearch"
             x:DataType="vm:BookingSearchViewModel">
    
    <StackPanel
    
        HorizontalAlignment="Center"
        Width="934"
        Spacing="30">

        <!-- Titre -->
        <TextBlock
            Text="Recherche réservation"
            FontFamily="Playfair Display"
            FontSize="48"
            HorizontalAlignment="Center"/>

        <!-- Formulaire -->
        <Border
            Background="#8BA89A"
            CornerRadius="12"
            Padding="50">

            <StackPanel Spacing="24">

                <Grid ColumnDefinitions="250,*">
                    <TextBlock
                        Grid.Column="0"
                        Text="Nom client :"
                        FontFamily="Montserrat"
                        FontSize="36"
                        VerticalAlignment="Center"/>

                    <TextBox
                        Text="{Binding LastName}"
                        Grid.Column="1"
                        Height="50"/>
                </Grid>

                <Grid ColumnDefinitions="250,*">
                    <TextBlock
                        Grid.Column="0"
                        Text="Prénom Client :"
                        FontFamily="Montserrat"
                        FontSize="36"
                        VerticalAlignment="Center"/>

                    <TextBox
                        Text="{Binding FirstName}"
                        Grid.Column="1"
                        Height="50"/>
                </Grid>
                
                <Grid ColumnDefinitions="250,*">
                    <TextBlock 
                        Text="{Binding ErrorMessage}" 
                        HorizontalAlignment="Center" 
                        VerticalAlignment="Center"/>
                </Grid>

            </StackPanel>
        </Border>

        <!-- Bouton -->
        <Button
            Width="254"
            Height="65"
            HorizontalAlignment="Center"
            Content="Se connecter"
            Command="{Binding SearchFoCheckinCommand}">

            <Button.Styles>
                <Style Selector="Button">
                    <Setter Property="Background" Value="#2D494C"/>
                    <Setter Property="Foreground" Value="#E0C64D"/>
                    <Setter Property="FontFamily" Value="Montserrat"/>
                    <Setter Property="FontSize" Value="32"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Style>
            </Button.Styles>

        </Button>

    </StackPanel>
</UserControl>
