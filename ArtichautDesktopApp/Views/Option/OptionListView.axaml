<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:option="clr-namespace:ArtichautDesktopApp.ViewModels.Option"
             xmlns:option1="clr-namespace:ArtichautDesktopApp.Views.Option"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ArtichautDesktopApp.Views.Option.OptionListView"
             x:DataType="option:OptionListViewModel">

    <Border
        Background="#2D494C"
        CornerRadius="10"
        Padding="24">

        <ItemsControl ItemsSource="{Binding Options}">

            <ItemsControl.ItemTemplate>

                <DataTemplate>

                    <option1:OptionRowView/>

                </DataTemplate>

            </ItemsControl.ItemTemplate>

        </ItemsControl>

    </Border>

</UserControl>