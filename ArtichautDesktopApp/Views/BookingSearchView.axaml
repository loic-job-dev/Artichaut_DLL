<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ArtichautDesktopApp.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ArtichautDesktopApp.Views.BookingSearchView"
             x:DataType="vm:BookingSearchViewModel">
    
    <StackPanel
    
        HorizontalAlignment="Center"
        Width="934"
        Spacing="30">

        <!-- Titre -->
        <TextBlock
            Text="Recherche réservation"
            Classes="h1"
            HorizontalAlignment="Center"/>

        <!-- Formulaire -->
        <Border
            Background="#8BA89A"
            CornerRadius="12"
            Padding="50">

            <StackPanel Spacing="24">

                <Grid ColumnDefinitions="250,*">
                    <TextBlock
                        Grid.Column="0"
                        Text="Nom client :"
                        Classes="h3"
                        VerticalAlignment="Center"/>

                    <TextBox
                        Text="{Binding LastName}"
                        Grid.Column="1"
                        Height="50"/>
                </Grid>

                <Grid ColumnDefinitions="250,*">
                    <TextBlock
                        Grid.Column="0"
                        Text="Prénom Client :"
                        Classes="h3"
                        VerticalAlignment="Center"/>

                    <TextBox
                        Text="{Binding FirstName}"
                        Grid.Column="1"
                        Height="50"/>
                </Grid>
                
                    <TextBlock 
                        Classes="error"
                        Text="{Binding ErrorMessage}" 
                        HorizontalAlignment="Center" 
                        VerticalAlignment="Center"/>
                    
            </StackPanel>
        </Border>

        <!-- Bouton -->
        <Button
            Width="254"
            Height="65"
            HorizontalAlignment="Center"
            Classes="primary"
            Content="Recherche"
            Command="{Binding GetBookingsToCheckinByClientCommand}">


        </Button>

    </StackPanel>
</UserControl>
